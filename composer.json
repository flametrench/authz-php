{
    "name": "flametrench/authz",
    "description": "Authorization primitives for Flametrench: relational tuples and exact-match check(). Spec-conformant; no rewrite rules in v0.1.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["flametrench", "authorization", "authz", "relational-tuples", "zanzibar"],
    "homepage": "https://flametrench.dev",
    "authors": [
        {
            "name": "NDC Digital, LLC",
            "homepage": "https://flametrench.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "flametrench/ids": "dev-v03-pat-prefix as 0.3.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ids-php",
            "options": { "symlink": false }
        }
    ],
    "suggest": {
        "ext-pdo": "Required by PostgresTupleStore for the durable backend.",
        "ext-pdo_pgsql": "Postgres driver for PostgresTupleStore."
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Flametrench\\Authz\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev"
}
